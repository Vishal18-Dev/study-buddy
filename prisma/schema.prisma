generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  passwordHash     String
  name             String?
  tier             String            @default("FREE")
  preference       String            @default("PLAN_ONLY")
  telegramId       String?
  createdAt        DateTime          @default(now())
  checkIns         CheckIn[]
  knowledgeSources KnowledgeSource[]
  plans            Plan[]
  quizResults      QuizResult[]
  streaks          Streak?
}

model Plan {
  id               String            @id @default(cuid())
  userId           String
  subject          String
  examDate         DateTime
  goalScore        Int
  dailyHours       Float
  status           String            @default("ACTIVE")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  knowledgeSources KnowledgeSource[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  days             PlanDay[]
}

model PlanDay {
  id        String   @id @default(cuid())
  planId    String
  dayNumber Int
  date      DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  topics    Topic[]
}

model Topic {
  id              String                @id @default(cuid())
  planDayId       String
  title           String
  estimatedMins   Int
  status          String                @default("NOT_STARTED")
  notes           String?
  quizResults     QuizResult[]
  planDay         PlanDay               @relation(fields: [planDayId], references: [id], onDelete: Cascade)
  recommendations TopicRecommendation[]
}

model Streak {
  id            String    @id @default(cuid())
  userId        String    @unique
  current       Int       @default(0)
  longest       Int       @default(0)
  graceDaysUsed Int       @default(0)
  lastCheckIn   DateTime?
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CheckIn {
  id             String   @id @default(cuid())
  userId         String
  planId         String
  completionFlag String
  sessionMins    Int      @default(0)
  note           String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuizResult {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  score     Int
  passed    Boolean
  questions String
  createdAt DateTime @default(now())
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SyllabusChunk {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  content   String
  createdAt DateTime @default(now())
}

model KnowledgeSource {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  title     String
  type      String
  url       String?
  content   String?
  createdAt DateTime @default(now())
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TopicRecommendation {
  id       String  @id @default(cuid())
  topicId  String
  title    String
  url      String
  isPaid   Boolean
  platform String
  rating   Int     @default(0)
  topic    Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
}
