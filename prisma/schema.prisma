generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  passwordHash     String
  name             String?
  tier             String            @default("FREE")
  preference       String            @default("PLAN_ONLY")
  telegramId       String?
  role             String            @default("STUDENT") // "STUDENT" or "TEACHER"
  createdAt        DateTime          @default(now())
  checkIns         CheckIn[]
  knowledgeSources KnowledgeSource[]
  plans            Plan[]
  quizResults      QuizResult[]
  streaks          Streak?
  classroomsTaught Classroom[]       @relation("TeacherClassrooms")
  classroomMembers ClassroomMember[]
}

model Plan {
  id                  String            @id @default(cuid())
  userId              String
  subject             String
  examDate            DateTime
  goalScore           Int
  dailyHours          Float
  status              String            @default("ACTIVE")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  isTeacherAssigned   Boolean           @default(false)
  teacherPlanAccepted Boolean           @default(false)
  currentScore        Int?
  teacherNotes        String?
  templateId          String?
  classroomId         String?
  knowledgeSources    KnowledgeSource[]
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template            PlanTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  classroom           Classroom?        @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  days                PlanDay[]
}

model PlanDay {
  id        String   @id @default(cuid())
  planId    String
  dayNumber Int
  date      DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  topics    Topic[]
}

model Topic {
  id              String                @id @default(cuid())
  planDayId       String
  title           String
  estimatedMins   Int
  status          String                @default("NOT_STARTED")
  notes           String?
  quizResults     QuizResult[]
  planDay         PlanDay               @relation(fields: [planDayId], references: [id], onDelete: Cascade)
  recommendations TopicRecommendation[]
}

model Streak {
  id            String    @id @default(cuid())
  userId        String    @unique
  current       Int       @default(0)
  longest       Int       @default(0)
  graceDaysUsed Int       @default(0)
  lastCheckIn   DateTime?
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CheckIn {
  id             String   @id @default(cuid())
  userId         String
  planId         String
  completionFlag String
  sessionMins    Int      @default(0)
  note           String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuizResult {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  score     Int
  passed    Boolean
  questions String
  createdAt DateTime @default(now())
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SyllabusChunk {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  content   String
  createdAt DateTime @default(now())
}

model KnowledgeSource {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  title     String
  type      String
  url       String?
  content   String?
  createdAt DateTime @default(now())
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TopicRecommendation {
  id       String  @id @default(cuid())
  topicId  String
  title    String
  url      String
  isPaid   Boolean
  platform String
  rating   Int     @default(0)
  topic    Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Classroom {
  id        String            @id @default(cuid())
  name      String
  code      String            @unique // 6-character uppercase alphanumeric code
  teacherId String
  createdAt DateTime          @default(now())
  teacher   User              @relation("TeacherClassrooms", fields: [teacherId], references: [id], onDelete: Cascade)
  members   ClassroomMember[]
  templates PlanTemplate[]
  plans     Plan[]
}

model ClassroomMember {
  id          String    @id @default(cuid())
  classroomId String
  studentId   String
  joinedAt    DateTime  @default(now())
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
}

model PlanTemplate {
  id              String    @id @default(cuid())
  classroomId     String
  subject         String
  syllabusContext String    // Syllabus topics or text
  createdAt       DateTime  @default(now())
  classroom       Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  plans           Plan[]
}
